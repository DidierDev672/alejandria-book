# URL base de la API Atreides (backend de la Casa Atreides)
# En desarrollo, el servidor suele ejecutarse en el puerto 8080
VITE_API_ATREIDES=http://localhost:8080

# =============================================================================
# SUPABASE CONFIGURATION
# =============================================================================
# Obtén estos valores desde https://supabase.com/dashboard → Settings → API

# URL del proyecto Supabase (requerido)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon Key - para operaciones de cliente (pública, limitada por RLS)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Service Role Key - tiene privilegios totales, bypass RLS
# ⚠️ ADVERTENCIA: Solo usar en desarrollo/backend. NUNCA en producción frontend.
# Descomenta solo si entiendes los riesgos de seguridad:
# VITE_SUPABASE_SERVICE_KEY=your-service-role-key-here

# Storage Bucket para videos (default: 'gallary')
VITE_SUPABASE_VIDEO_BUCKET=gallary

# =============================================================================
# NOTAS DE SEGURIDAD SUPABASE:
# =============================================================================
#
# Si recibes error "403 Invalid Compact JWS" al subir videos:
#
# OPCIÓN 1 - Desarrollo rápido (menos seguro):
#   - Usa VITE_SUPABASE_SERVICE_KEY (tiene privilegios totales)
#   - O deshabilita RLS en Supabase Dashboard → Storage → Policies
#
# OPCIÓN 2 - Producción segura (recomendado):
#   - Configura políticas RLS en el bucket 'gallary':
#     1. Ve a Supabase Dashboard → Storage → gallary → Policies
#     2. Habilita "Allow public uploads" o
#     3. Crea política: INSERT para "anon" o "authenticated"
#   - Usa solo VITE_SUPABASE_ANON_KEY
#
# OPCIÓN 3 - Backend proxy (más seguro):
#   - No subas videos desde el frontend
#   - Envía el archivo a tu backend
#   - El backend usa Service Key para subir a Supabase
#
# =============================================================================
