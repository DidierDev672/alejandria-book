{"nodes": [{"id": "docs_dune_alexandria_technical_changelog", "label": "Technical Changelog Dune Alexandria", "file_type": "document", "source_file": "docs/DUNE-ALEXANDRIA.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_dune_alexandria_video_upload", "label": "Video Upload to Supabase", "file_type": "concept", "source_file": "docs/DUNE-ALEXANDRIA.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Video uploaded to Supabase Storage before exercise creation. Architecture uses Onion layers: UI/Composable/Application/Domain/Infrastructure. Decouples video upload from exercise creation for separation of concerns."}, {"id": "docs_dune_alexandria_gom_jabbar_modals", "label": "Gom Jabbar Three Stage Modal Architecture", "file_type": "concept", "source_file": "docs/DUNE-ALEXANDRIA.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Three modals map to stages of knowledge: Hall of Verification (ConfirmModal), Hall of Acclaim (SuccessModal), Hall of Errors (ErrorModal). Each modal serves a distinct purpose in the upload flow."}, {"id": "docs_dune_alexandria_stillsuit_principle", "label": "Stillsuit Graceful Degradation", "file_type": "rationale", "source_file": "docs/DUNE-ALEXANDRIA.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "If Supabase config fails, system does not collapse. try/catch sets composable to null, form falls back to creating exercise without video. User sees no error \u2014 system adapts like Fremen stillsuit recycling moisture."}, {"id": "docs_dune_alexandria_validation_system", "label": "Janitor Gate Validation System", "file_type": "concept", "source_file": "docs/DUNE-ALEXANDRIA.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Three validation gates before form submission: name (required/2-100 chars/must contain letter), difficulty (must be enum), video (optional but validated if present). Like gatekeeper inspecting gladiator before arena."}, {"id": "docs_dune_alexandria_vertical_slice", "label": "Vertical Slice Implementation", "file_type": "concept", "source_file": "docs/DUNE-ALEXANDRIA.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_dune_alexandria_pinia_collision", "label": "Pinia Store ID Collision Fix", "file_type": "concept", "source_file": "docs/DUNE-ALEXANDRIA.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Two stores used same ID 'equipment'. JS store had equipmentList, TS store had equipments. Navigation order determined which won, causing undefined.length crash. Fixed by renaming TS store ID to 'maintenance-equipment'."}, {"id": "docs_dune_alexandria_template_fix", "label": "Template Compilation Fix", "file_type": "concept", "source_file": "docs/DUNE-ALEXANDRIA.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}], "edges": [{"source": "docs_dune_alexandria_technical_changelog", "target": "docs_dune_alexandria_video_upload", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/DUNE-ALEXANDRIA.md", "source_location": null, "weight": 1.0}, {"source": "docs_dune_alexandria_technical_changelog", "target": "docs_dune_alexandria_gom_jabbar_modals", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/DUNE-ALEXANDRIA.md", "source_location": null, "weight": 1.0}, {"source": "docs_dune_alexandria_technical_changelog", "target": "docs_dune_alexandria_stillsuit_principle", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/D